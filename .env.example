# Aurora Rayes Books Agent environment variables
# Copy to .env.local for local development. Use placeholders only in source control.

NEXT_PUBLIC_APP_NAME=Aurora Rayes Books Agent
NEXT_PUBLIC_APP_URL=https://aurora-booksai.example
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# AI
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini
# Privacy-first defaults
LOG_LEVEL=info
APP_DATA_RETENTION_DAYS=0

# Payments are disabled unless this is explicitly true in deployment secrets.
CHECKOUT_ENABLED=false
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_PRICE_PRO_MONTHLY=REPLACE_WITH_STRIPE_PRICE_PRO_MONTHLY
STRIPE_PRICE_PRO_YEARLY=REPLACE_WITH_STRIPE_PRICE_PRO_YEARLY

# Database, if enabled by your deployment
DATABASE_URL=REPLACE_WITH_DATABASE_URL
